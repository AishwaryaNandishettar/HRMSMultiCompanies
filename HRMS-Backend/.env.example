# HRMS Backend Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to git!

# ====================================
# TWILIO SMS CONFIGURATION
# ====================================
# Get these from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_VERIFIED_NUMBERS=+919606408912,+919930145419

# ====================================
# DATABASE CONFIGURATION
# ====================================
# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/hrms

# ====================================
# JWT CONFIGURATION
# ====================================
JWT_SECRET=your_jwt_secret_here

# ====================================
# EMAIL CONFIGURATION
# ====================================
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_app_password_here

# ====================================
# DEPLOYMENT INSTRUCTIONS
# ====================================
# For Render.com:
# 1. Go to Dashboard > Your Service > Environment
# 2. Add each variable above with your actual values
#
# For Railway.app:
# 1. Go to your project > Variables
# 2. Add each variable with your actual values
#
# For Vercel (if using Next.js frontend):
# 1. Go to Project Settings > Environment Variables
# 2. Add NEXT_PUBLIC_ prefix for client-side variables
